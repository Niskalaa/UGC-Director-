# Gunakan image Python (atau node:18 untuk JavaScript)
FROM python:3.10-slim

# Set working directory
WORKDIR /app

# Copy requirements dan install
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy seluruh kode project
COPY . .

# Port default yang digunakan AWS App Runner
EXPOSE 8080

# Jalankan aplikasi (sesuaikan dengan file utama kamu)
CMD ["python", "main.py"]
